*population 
graph hbar (asis) female_population_share ///
    male_population_share if time_period == 2023, ///
    over(geo, sort(1) descending label(labsize(vsmall))) ///
    stack ///
	bar(1, color(blue))      ///
	bar(2, color(purple))   ///
    legend(order(1 "Female" 2 "Male")) ///
