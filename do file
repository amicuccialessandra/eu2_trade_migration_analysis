EU27 TRADE OPENNESS AND NET MIGRATION
 Country-year panel, 2013–2023
 Author: Amicucci Alessandra 14/07/2026 
 
 Dataset: Eurostat 
 Variable: Migration migr_netmigr / Trade ext_lt_intratrd (exports + imports, extra-EA, million €) / GDP nama_10_gdp (B1GQ) / Population demo_pjan / Investment nama_10_gdp(P51G) / Inflation prc_hicp_aind
 
 Unit of observation: EU27 country × year
 Number of countries: 27
 Number of years: 11
 Expected observations: 297
*******************************************************************************/

clear all
set more off
capture log close

**# path and globals

global data "C:\Documenti\data"
global EU "AT BE BG HR CY CZ DK EE FI FR DE EL HU IE IT LV LT LU MT NL PL PT RO SK SI ES SE"

**# prepare dataset

*1.1 net migration
import delimited "$data\migr_netmigr.csv", clear 

*keep only the variables needed
keep geo obs_value time_period
keep if inrange(time_period, 2013, 2023)

rename obs_value net_migration
label variable net_migration "Net migration, persons"

*check if observation are unique
isid geo time_period
save "$data\migration", replace


**1.2 population 
import delimited "$data\demo_pjan.csv", clear 
keep sex age geo time_period obs_value
keep if inrange(time_period, 2013, 2023)

* Keep the total age category
keep if age == "TOTAL"

*convert the gender categories from rows to column 
reshape wide obs_value, i(geo time_period) j(sex) string

drop age

rename obs_valueT total_population
rename obs_valueM male_population
rename obs_valueF female_population

label variable total_population  "Total population"
label variable male_population   "Male population"
label variable female_population "Female population"

* Check whether total population equals female plus male population
gen pop_difference = total_population - (female_population + male_population)

summarize pop_difference, detail
/*
 RESULT:
 pop_difference is equal to zero for all 297 country-year observations.

 Therefore, total population exactly equals the sum of female and male
 population in every country and year. The population-by-sex data are
 internally consistent.
*/


list geo time_period total_population ///
    female_population male_population pop_difference ///
    if pop_difference != 0

* Construct population shares by sex
gen female_population_share = 100 * female_population / total_population

label variable female_population_share "Female share of total population (%)"

gen male_population_share = 100 * male_population / total_population

label variable male_population_share "Male share of total population (%)"
	
summarize female_population_share  male_population_share


assert inrange(female_population_share, 0, 100)
assert inrange(male_population_share, 0, 100)

isid geo time_period
save "$data\demo", replace


*1.3 extra-EU trade 
import delimited "$data\ext_intratrd.csv", clear 
keep geo time_period obs_value indic_et

isid geo time_period indic_et

* Convert export and import indicators into separate variables
reshape wide obs_value, i(geo time_period) j(indic_et) string

rename obs_valueMIO_EXP_VAL exp
rename obs_valueMIO_IMP_VAL imp

label variable exp "Extra-EU exports"
label variable imp "Extra-EU imports"

keep if inrange(time_period, 2013, 2023)
save "$data\trade", replace

import delimited "$data\gdp.csv", clear

*1.4 GDP and Investment 
keep na_item geo time_period obs_value

isid geo time_period na_item

reshape wide obs_value, i(geo time_period) j(na_item) string
rename obs_valueB1GQ GDP
rename obs_valueP51G Investment


label variable GDP "Gross domestic product"

label variable Investment "Gross fixed capital formation"
	
keep if inrange(time_period, 2013, 2023)

isid geo time_period
save "$data\gdp", replace


*1.5 inflation 
import delimited "$data\hicp.csv", clear 
keep geo time_period obs_value 

rename obs_value inflation

keep if inrange(time_period, 2013, 2023)

isid geo time_period
save "$data\hicp", replace


**# 2. Construct the EU27 country-year panel

* Use net migration as the master country-year dataset
use "$data\migration", clear
gen eu27 = 0

foreach country of global EU {
    replace eu27 = 1 if geo == "`country'"
}

keep if eu27 == 1
drop eu27

* Expected structure before merging: 27 countries × 11 years
merge 1:1 geo time_period using "$data\demo.dta"
tab _merge
drop _merge

merge 1:1 geo time_period using "$data\trade"
tab _merge
drop _merge

merge 1:1 geo time_period using "$data\gdp"
tab _merge
drop _merge

merge 1:1 geo time_period using "$data\hicp"
tab _merge
drop _merge


** Validate and save merged data

sort geo time_period

isid geo time_period
assert _N == 297
gen eu27 = 0

foreach country of global EU {
    replace eu27 = 1 if geo == "`country'"
}

keep if eu27 == 1
tab eu27
assert eu27 == 1
drop eu27

save "$data\dataset", replace


**# 3. Construct analytical variables
* Population and GDP must be positive.
assert total_population > 0
assert GDP > 0
assert Investment >= 0
assert exp >= 0
assert imp >= 0

*Trade indicators 
gen extra_eu_trade = exp + imp if !missing(exp, imp)
label variable extra_eu_trade "Extra-EU exports plus imports, million euro"

*extra EU trade relative to the size of the nation
gen trade_openness = 100 * extra_eu_trade / GDP if GDP > 0
label variable trade_openness "Extra-EU trade as % of GDP"

*export and import component 
gen export_gdp = 100 * exp / GDP if GDP > 0
gen import_gdp = 100 * imp / GDP if GDP > 0

label variable export_gdp "Extra-EU exports as % of GDP"
label variable import_gdp "Extra-EU imports as % of GDP"

*trade balance 
gen trade_balance = exp - imp if !missing(exp, imp)
gen trade_balance_gdp = 100 * trade_balance / GDP if GDP > 0


*investment rate 
gen investment_rate = 100 * Investment / GDP if GDP > 0
label variable investment_rate "Gross fixed capital formation as % of GDP"

* GDP per capita 
gen gdp_pc = (GDP * 1000000) / total_population if GDP > 0 & total_population > 0
label variable gdp_pc "GDP per capita, euro"

*control
summarize gdp_pc, detail

*logaritm reduce the scale differences 
gen ln_gdp_pc = ln(gdp_pc) if gdp_pc > 0
label variable ln_gdp_pc "Log GDP per capita"

*net migration rate 
gen net_migration_rate = ///
    1000 * net_migration / total_population

label variable net_migration_rate ///
    "Net migration per 1,000 inhabitants"
	
**# Panel
encode geo, gen(country_id)
xtset country_id time_period
xtdescribe //Checks whether the panel is balanced and whether country time series have gaps

/*
 RESULT:
 The panel is strongly balanced.

 - 27 countries
 - 11 annual observations per country
 - Period: 2013–2023
 - 297 country-year observations
 - No gaps or duplicate country-year observations
*/

* Checks missing values in the regression variables
misstable summarize net_migration_rate ln_gdp_pc trade_openness investment_rate inflation

/*
 RESULT:
 All five regression variables contain 297 nonmissing observations.
 The baseline regressions therefore use the complete EU27 panel.
*/

summarize net_migration_rate gdp_pc trade_openness investment_rate inflation, detail

/*
 RESULTS FROM THE CURRENT DATA:

 Net migration rate
 - Mean: 4.59 per 1,000 inhabitants
 - Minimum: -8.60
 - Maximum: 43.06
 - The distribution is positively skewed, reflecting high migration
   rates in some smaller EU countries.

 GDP per capita
 - Mean: approximately EUR 31,244
 - Minimum: approximately EUR 5,839
 - Maximum: approximately EUR 124,265

 Extra-EU trade openness
 - Mean: 31.82% of GDP
 - Minimum: 6.72%
 - Maximum: 99.47%

 Investment rate
 - Mean: 21.32% of GDP
 - Minimum: 10.97%
 - Maximum: 53.23%

 Inflation
 - Mean: 2.56%
 - Minimum: -1.6%
 - Maximum: 19.4%
*/

*within country and between country variation 
xtsum net_migration_rate ln_gdp_pc trade_openness investment_rate inflation

/*
 RESULT:
 All explanatory variables exhibit within-country variation.

 Trade openness:
 - Between-country standard deviation: 14.20
 - Within-country standard deviation: 5.41

 Net migration rate:
 - Between-country standard deviation: 5.73
 - Within-country standard deviation: 5.22

 The variables therefore contain sufficient time variation for
 a fixed-effects analysis.
*/

**# Regression

/*
 The model estimates whether changes in trade openness within a country
 are associated with changes in its net migration rate.

 Country fixed effects control for time-invariant national characteristics.
 Year fixed effects control for common EU-wide shocks.
 Standard errors are clustered at the country level.
*/


xtreg net_migration_rate trade_openness ln_gdp_pc investment_rate inflation i.time_period, fe vce(cluster country_id)
estimates store trade_aggregate

/*
 CURRENT RESULTS:

 Trade openness:
 - Coefficient: -0.0556
 - p-value: 0.155
 - Negative association, but not statistically significant.

 Log GDP per capita:
 - Coefficient: 15.7996
 - p-value: 0.010
 - Positive and statistically significant.
 - A 1% increase in GDP per capita is associated with approximately
   0.158 additional net migrants per 1,000 inhabitants.

 Investment rate:
 - Coefficient: 0.2195
 - p-value: 0.187
 - Not statistically significant.

 Inflation:
 - Coefficient: 0.2680
 - p-value: 0.467
 - Not statistically significant.

 Within R-squared: 0.4464

 Interpretation:
 Extra-EU trade openness is not significantly associated with net migration. GDP per capita is the only statistically significant macroeconomic predictor in the baseline specification.
*/

*Decomposition into exports and imports 
xtreg net_migration_rate export_gdp import_gdp ln_gdp_pc investment_rate inflation i.time_period, fe vce(cluster country_id)
estimates store trade_split

/*
 CURRENT RESULTS:

 Extra-EU exports:
 - Coefficient: -0.4254
 - p-value: 0.209
 - Negative but not statistically significant.

 Extra-EU imports:
 - Coefficient: 0.2103
 - p-value: 0.366
 - Positive but not statistically significant.

 Log GDP per capita remains positive and significant:
 - Coefficient: 14.2840
 - p-value: 0.012

 Within R-squared: 0.4541

 The opposite signs are suggestive, but the separate coefficients
 cannot be interpreted as statistically established differences.
*/


* Tests for the export-import decomposition
test export_gdp import_gdp

/*
 RESULT:
 F-test p-value = 0.2434.

 Exports and imports are not jointly statistically significant.
*/

* Test whether the export and import coefficients are different.
test export_gdp = import_gdp
/*
 RESULT:
 F-test p-value = 0.2612.

 The null hypothesis that the two coefficients are equal cannot be rejected.
*/

pwcorr export_gdp import_gdp, sig
/*
 RESULT:
 Correlation = 0.7892
 p-value < 0.001

 Export and import exposure are strongly correlated. This may increase
 the standard errors when both variables are included simultaneously.
*/

*Population decompostition
xtreg net_migration_rate trade_openness ln_gdp_pc investment_rate inflation female_population_share i.time_period, fe vce(cluster country_id)

estimates store sex_control
/*
 CURRENT RESULTS:

 Female population share:
 - Coefficient: -0.7113
 - p-value: 0.709
 - Not statistically significant.

 Trade openness:
 - Coefficient: -0.0546
 - p-value: 0.149

 Log GDP per capita:
 - Coefficient: 15.7846
 - p-value: 0.008

 Within R-squared: 0.4471

 Adding the female population share leaves the trade-openness and
 GDP-per-capita coefficients almost unchanged. The baseline findings
 are therefore robust to this additional demographic control.
*/

save "$data\dataset", replace


capture which esttab

if _rc == 0 {

    esttab trade_aggregate trade_split sex_control ///
        using "$data\output\regression_results.rtf", ///
        replace ///
        b(3) se(3) ///
        star(* 0.10 ** 0.05 *** 0.01) ///
        mtitles("Aggregate trade" ///
                "Exports and imports" ///
                "Sex composition") ///
        keep(trade_openness export_gdp import_gdp ///
             ln_gdp_pc investment_rate inflation ///
             female_population_share) ///
        stats(N r2_w, ///
              fmt(0 3) ///
              labels("Observations" "Within R-squared")) ///
        indicate("Year fixed effects = *.time_period") ///
        addnotes("Country fixed effects included.", ///
                 "Standard errors clustered by country.")

}


